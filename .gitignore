
###############################################################################
# Terraform
###############################################################################

# Local Terraform directory
.terraform/

# Terraform state
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# Lock file (khuyến nghị commit để cố định provider version)
#! .terraform.lock.hcl

###############################################################################
# Variables
###############################################################################

# Không commit file chứa thông tin thực tế
terraform.tfvars
*.auto.tfvars

# Chỉ commit file ví dụ
!terraform.tfvars.example

